DISCORD_BOT_TOKEN="your_bot_token_here"
# Optional: guild id for instant command sync while testing
DISCORD_GUILD_ID="1425842636773789768"
# Optional: restrict /shuffle_teams to a single channel
ALLOWED_CHANNEL_ID="1481764374569025671"
# Optional: path inside the container or local project
BOT_ADMINS_FILE="data/bot_admins.json"

POSTGRES_DB="northgard_bot"
POSTGRES_USER="northgard_bot"
POSTGRES_PASSWORD="change_me"
DATABASE_URL="postgresql://northgard_bot:change_me@postgres:5432/northgard_bot"
# Optional: run pytest before starting the bot. Keep disabled in production unless needed.
RUN_TESTS_ON_STARTUP="0"
